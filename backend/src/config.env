# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE=mongodb+srv://<username>:<password>@cluster0.mongodb.net/tmg-makerspace?retryWrites=true&w=majority
DATABASE_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60 * 60 * 1000
RATE_LIMIT_MAX=100


